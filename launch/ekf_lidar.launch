<launch>
    <arg name="imu_topic" default="/mavros/imu/data"/>
    <arg name="odom_primary_topic" default="/mavros/odometry/in"/>
    <arg name="odom_fallback_topic" default="/unused_odom_fallback"/>
    <arg name="gnss_topic" default="/mavros/global_position/global"/>
    <arg name="use_gnss" default="true"/>
    <arg name="enable_gnss_cold_start" default="true"/>
    <arg name="gnss_cold_start_delay" default="1.0"/>
    <arg name="gnss_cold_start_frame_id" default="odom"/>
    <arg name="gnss_update_only_when_odom_lost" default="false"/>
    <arg name="enable_gnss_position_snap_when_odom_lost" default="false"/>
    <arg name="gyro_cov" default="0.5"/>
    <arg name="acc_cov" default="1.0"/>
    <arg name="position_cov" default="0.005"/>
    <arg name="q_rp_cov" default="10.0"/>
    <arg name="q_yaw_cov" default="0.05"/>
    <arg name="cutoff_freq" default="20.0"/>
    <arg name="enable_output_motion_smoothing" default="true"/>
    <arg name="output_smoothing_natural_freq" default="3.0"/>
    <arg name="output_smoothing_damping_ratio" default="1.0"/>
    <arg name="output_smoothing_max_accel" default="50.0"/>
    <arg name="output_smoothing_max_correction_speed" default="20.0"/>
    <arg name="output_smoothing_normal_natural_freq" default="3.5"/>
    <arg name="output_smoothing_normal_max_accel" default="50.0"/>
    <arg name="output_smoothing_normal_max_correction_speed" default="20.0"/>
    <arg name="output_smoothing_release_error" default="0.005"/>
    <arg name="output_smoothing_recovery_duration" default="0.8"/>
    <arg name="gnss_min_interval" default="0.5"/>
    <arg name="gnss_min_cov_xy" default="16.0"/>
    <arg name="gnss_min_cov_z" default="25.0"/>
    <arg name="gnss_cov_scale" default="1.0"/>
    <arg name="gnss_position_covariance_floor_xy" default="0.0"/>
    <arg name="gnss_position_covariance_floor_z" default="0.0"/>
    <arg name="enable_gnss_mahalanobis_gate" default="true"/>
    <arg name="gnss_mahalanobis_weak_threshold" default="7.815"/>
    <arg name="gnss_mahalanobis_reject_threshold" default="16.266"/>
    <arg name="enable_gnss_motion_consistency" default="true"/>
    <arg name="gnss_motion_consistency_min_motion" default="0.5"/>
    <arg name="gnss_motion_consistency_threshold" default="1.0"/>
    <arg name="gnss_motion_consistency_reject_threshold" default="3.0"/>
    <arg name="gnss_motion_consistency_max_scale" default="10.0"/>
    <arg name="gnss_healthy_odom_weak_scale" default="0.5"/>
    <arg name="enable_gnss_health_score" default="true"/>
    <arg name="gnss_good_covariance_xy" default="4.0"/>
    <arg name="gnss_poor_covariance_xy" default="16.0"/>
    <arg name="gnss_min_health_score" default="0.2"/>
    <arg name="gnss_health_trust_threshold" default="0.75"/>
    <arg name="odom_weak_health_threshold" default="0.8"/>
    <arg name="gnss_health_low_score_max_scale" default="8.0"/>
    <arg name="enable_gnss_nis_state_machine" default="true"/>
    <arg name="gnss_health_window_size" default="5"/>
    <arg name="gnss_degraded_count_threshold" default="3"/>
    <arg name="gnss_severe_count_threshold" default="3"/>
    <arg name="gnss_recover_count_threshold" default="3"/>
    <arg name="gnss_isolation_time" default="1.0"/>
    <arg name="gnss_nis_degraded_threshold" default="7.815"/>
    <arg name="gnss_nis_severe_threshold" default="16.266"/>
    <arg name="gnss_r_degraded_scale" default="5.0"/>
    <arg name="gnss_r_severe_scale" default="20.0"/>
    <arg name="enable_odom_gnss_consistency_health" default="true"/>
    <arg name="odom_gnss_consistency_threshold" default="0.4"/>
    <arg name="odom_gnss_consistency_poor_threshold" default="1.2"/>
    <arg name="odom_gnss_consistency_max_scale" default="25.0"/>
    <arg name="odom_gnss_consistency_timeout" default="2.0"/>
    <arg name="enable_gnss_yaw_alignment" default="true"/>
    <arg name="gnss_require_yaw_alignment_before_update" default="true"/>
    <arg name="gnss_alignment_min_samples" default="5"/>
    <arg name="gnss_alignment_max_samples" default="120"/>
    <arg name="gnss_alignment_min_motion" default="20.0"/>
    <arg name="gnss_alignment_sample_interval" default="0.5"/>
    <arg name="gnss_odom_sync_max_dt" default="0.2"/>
    <arg name="gnss_alignment_max_residual" default="3.0"/>
    <arg name="enable_gnss_alignment_refinement" default="true"/>
    <arg name="gnss_alignment_refinement_min_samples" default="20"/>
    <arg name="gnss_alignment_refinement_max_samples" default="60"/>
    <arg name="gnss_alignment_refinement_min_motion" default="12.0"/>
    <arg name="gnss_alignment_refinement_max_residual" default="2.0"/>
    <arg name="gnss_alignment_refinement_gain" default="0.35"/>
    <arg name="gnss_alignment_refinement_max_yaw_step" default="0.35"/>
    <arg name="gnss_alignment_refinement_max_translation_step" default="5.0"/>
    <arg name="enable_odom_realign" default="true"/>
    <arg name="odom_use_msg_covariance" default="false"/>
    <arg name="odom_msg_min_position_cov" default="0.01"/>
    <arg name="odom_msg_min_orientation_cov" default="0.01"/>
    <arg name="enable_adaptive_observation_covariance" default="true"/>
    <arg name="odom_loss_timeout" default="1.0"/>
    <arg name="enable_odom_recovery_guard" default="true"/>
    <arg name="odom_recovery_frames" default="45"/>
    <arg name="odom_recovery_scale" default="1000.0"/>
    <arg name="odom_recovery_min_scale" default="1.0"/>
    <arg name="enable_gnss_velocity_when_odom_lost" default="false"/>
    <arg name="gnss_velocity_min_dt" default="0.05"/>
    <arg name="gnss_velocity_max_dt" default="1.5"/>
    <arg name="gnss_velocity_cov" default="1.0"/>
    <arg name="gnss_velocity_window_size" default="2"/>
    <arg name="gnss_velocity_smoothing_alpha" default="1.0"/>
    <arg name="gyro_bias_rw_cov" default="0.0"/>
    <arg name="acc_bias_rw_cov" default="0.0"/>
    <arg name="path_publish_stride" default="1"/>
    <arg name="start_display_frames" default="true"/>
    <arg name="start_review_paths" default="true"/>
    <arg name="start_rviz" default="true"/>
    <arg name="rviz_config" default="$(find ekf)/launch/ekf_lidar_minimal.rviz"/>
    <arg name="use_sim_time" default="true"/>

    <param name="/use_sim_time" type="bool" value="$(arg use_sim_time)"/>
    
    <node pkg="ekf" type="ekf" name="ekf" output="screen">
        <!--
            Public dataset/topic contract:
            - Keep the private names (~imu, ~bodyodometry_primary, ~gnss_fix)
              unchanged in C++.
            - Adapt new bags by overriding the launch args below instead of
              editing source topic names.
            - The default output remains /ekf/ekf_odom for downstream scripts,
              RViz configs, and reproduction notes.
        -->
        <remap from="~imu" to="$(arg imu_topic)"/>
        <remap from="~bodyodometry_primary" to="$(arg odom_primary_topic)"/>
        <remap from="~bodyodometry_fallback" to="$(arg odom_fallback_topic)"/>
        <remap from="~gnss_fix" to="$(arg gnss_topic)"/>

        <remap from="~ekf_odom" to="/ekf/ekf_odom"/>

        <!-- Static IMU/extrinsic parameters and gravity scale. -->
        <rosparam file="$(find ekf)/launch/PX4_vio_drone.yaml" command="load" />

        <!-- Output-only position offset applied immediately before publishing /ekf/ekf_odom. -->
        <param name="offset_px" type="double" value="0.0"/> 
        <param name="offset_py" type="double" value="0.0"/> 
        <param name="offset_pz" type="double" value="0.0"/> 
        
        <!-- Lever-arm from EKF body center to the published IMU/body output point. -->
        <param name="imu_trans_x" type="double" value="0.0"/> 
        <param name="imu_trans_y" type="double" value="0.0"/> 
        <!-- <param name="imu_trans_z" type="double" value="0.0"/>  -->
        <param name="imu_trans_z" type="double" value="0.0"/> 

        <!-- IMU process noise Qt: smaller values trust IMU propagation more. -->
        <param name="gyro_cov" type="double" value="$(arg gyro_cov)"/> 
        <param name="acc_cov" type="double" value="$(arg acc_cov)"/>
        <!-- Odom pose measurement noise Rt: smaller values trust odom updates more. -->
        <param name="position_cov" type="double" value="$(arg position_cov)"/>
        <param name="q_rp_cov" type="double" value="$(arg q_rp_cov)"/>
        <param name="q_yaw_cov" type="double" value="$(arg q_yaw_cov)"/>
        <param name="cutoff_freq" type="double" value="$(arg cutoff_freq)"/>
        <param name="enable_output_motion_smoothing" type="bool" value="$(arg enable_output_motion_smoothing)"/>
        <param name="output_smoothing_natural_freq" type="double" value="$(arg output_smoothing_natural_freq)"/>
        <param name="output_smoothing_damping_ratio" type="double" value="$(arg output_smoothing_damping_ratio)"/>
        <param name="output_smoothing_max_accel" type="double" value="$(arg output_smoothing_max_accel)"/>
        <param name="output_smoothing_max_correction_speed" type="double" value="$(arg output_smoothing_max_correction_speed)"/>
        <param name="output_smoothing_normal_natural_freq" type="double" value="$(arg output_smoothing_normal_natural_freq)"/>
        <param name="output_smoothing_normal_max_accel" type="double" value="$(arg output_smoothing_normal_max_accel)"/>
        <param name="output_smoothing_normal_max_correction_speed" type="double" value="$(arg output_smoothing_normal_max_correction_speed)"/>
        <param name="output_smoothing_release_error" type="double" value="$(arg output_smoothing_release_error)"/>
        <param name="output_smoothing_recovery_duration" type="double" value="$(arg output_smoothing_recovery_duration)"/>
        <param name="publish_warmup_frames" type="int" value="0"/>
        <param name="odom_jump_threshold" type="double" value="2.0"/>
        <param name="innovation_reject_threshold" type="double" value="1.5"/>
        <param name="innovation_reset_threshold" type="double" value="2.0"/>
        <param name="odom_use_msg_covariance" type="bool" value="$(arg odom_use_msg_covariance)"/>
        <param name="odom_msg_min_position_cov" type="double" value="$(arg odom_msg_min_position_cov)"/>
        <param name="odom_msg_min_orientation_cov" type="double" value="$(arg odom_msg_min_orientation_cov)"/>
        <param name="enable_odom_realign" type="bool" value="$(arg enable_odom_realign)"/>
        <param name="enable_adaptive_observation_covariance" type="bool" value="$(arg enable_adaptive_observation_covariance)"/>
        <param name="odom_adaptive_threshold" type="double" value="1.5"/>
        <param name="odom_adaptive_reject_threshold" type="double" value="4.0"/>
        <param name="odom_adaptive_max_scale" type="double" value="100.0"/>
        <param name="odom_loss_timeout" type="double" value="$(arg odom_loss_timeout)"/>
        <param name="enable_odom_recovery_guard" type="bool" value="$(arg enable_odom_recovery_guard)"/>
        <param name="odom_recovery_frames" type="int" value="$(arg odom_recovery_frames)"/>
        <param name="odom_recovery_scale" type="double" value="$(arg odom_recovery_scale)"/>
        <param name="odom_recovery_min_scale" type="double" value="$(arg odom_recovery_min_scale)"/>
        <param name="enable_gnss_velocity_when_odom_lost" type="bool" value="$(arg enable_gnss_velocity_when_odom_lost)"/>
        <param name="gnss_velocity_min_dt" type="double" value="$(arg gnss_velocity_min_dt)"/>
        <param name="gnss_velocity_max_dt" type="double" value="$(arg gnss_velocity_max_dt)"/>
        <param name="gnss_velocity_cov" type="double" value="$(arg gnss_velocity_cov)"/>
        <param name="gnss_velocity_window_size" type="int" value="$(arg gnss_velocity_window_size)"/>
        <param name="gnss_velocity_smoothing_alpha" type="double" value="$(arg gnss_velocity_smoothing_alpha)"/>
        <param name="gyro_bias_rw_cov" type="double" value="$(arg gyro_bias_rw_cov)"/>
        <param name="acc_bias_rw_cov" type="double" value="$(arg acc_bias_rw_cov)"/>
        <param name="gnss_adaptive_threshold" type="double" value="3.0"/>
        <param name="gnss_adaptive_reject_threshold" type="double" value="5.0"/>
        <param name="gnss_adaptive_max_scale" type="double" value="25.0"/>
        <param name="odom_realign_settle_frames" type="int" value="20"/>
        <param name="odom_source_switch_grace" type="double" value="0.5"/>
        <param name="use_gnss" type="bool" value="$(arg use_gnss)"/>
        <param name="enable_gnss_cold_start" type="bool" value="$(arg enable_gnss_cold_start)"/>
        <param name="gnss_cold_start_delay" type="double" value="$(arg gnss_cold_start_delay)"/>
        <param name="gnss_cold_start_frame_id" type="str" value="$(arg gnss_cold_start_frame_id)"/>
        <param name="gnss_update_only_when_odom_lost" type="bool" value="$(arg gnss_update_only_when_odom_lost)"/>
        <param name="enable_gnss_position_snap_when_odom_lost" type="bool" value="$(arg enable_gnss_position_snap_when_odom_lost)"/>
        <param name="gnss_use_msg_covariance" type="bool" value="true"/>
        <param name="gnss_min_interval" type="double" value="$(arg gnss_min_interval)"/>
        <param name="gnss_min_cov_xy" type="double" value="$(arg gnss_min_cov_xy)"/>
        <param name="gnss_min_cov_z" type="double" value="$(arg gnss_min_cov_z)"/>
        <param name="gnss_cov_scale" type="double" value="$(arg gnss_cov_scale)"/>
        <param name="gnss_position_covariance_floor_xy" type="double" value="$(arg gnss_position_covariance_floor_xy)"/>
        <param name="gnss_position_covariance_floor_z" type="double" value="$(arg gnss_position_covariance_floor_z)"/>
        <param name="enable_gnss_mahalanobis_gate" type="bool" value="$(arg enable_gnss_mahalanobis_gate)"/>
        <param name="gnss_mahalanobis_weak_threshold" type="double" value="$(arg gnss_mahalanobis_weak_threshold)"/>
        <param name="gnss_mahalanobis_reject_threshold" type="double" value="$(arg gnss_mahalanobis_reject_threshold)"/>
        <param name="enable_gnss_motion_consistency" type="bool" value="$(arg enable_gnss_motion_consistency)"/>
        <param name="gnss_motion_consistency_min_motion" type="double" value="$(arg gnss_motion_consistency_min_motion)"/>
        <param name="gnss_motion_consistency_threshold" type="double" value="$(arg gnss_motion_consistency_threshold)"/>
        <param name="gnss_motion_consistency_reject_threshold" type="double" value="$(arg gnss_motion_consistency_reject_threshold)"/>
        <param name="gnss_motion_consistency_max_scale" type="double" value="$(arg gnss_motion_consistency_max_scale)"/>
        <param name="gnss_healthy_odom_weak_scale" type="double" value="$(arg gnss_healthy_odom_weak_scale)"/>
        <param name="enable_gnss_health_score" type="bool" value="$(arg enable_gnss_health_score)"/>
        <param name="gnss_good_covariance_xy" type="double" value="$(arg gnss_good_covariance_xy)"/>
        <param name="gnss_poor_covariance_xy" type="double" value="$(arg gnss_poor_covariance_xy)"/>
        <param name="gnss_min_health_score" type="double" value="$(arg gnss_min_health_score)"/>
        <param name="gnss_health_trust_threshold" type="double" value="$(arg gnss_health_trust_threshold)"/>
        <param name="odom_weak_health_threshold" type="double" value="$(arg odom_weak_health_threshold)"/>
        <param name="gnss_health_low_score_max_scale" type="double" value="$(arg gnss_health_low_score_max_scale)"/>
        <param name="enable_gnss_nis_state_machine" type="bool" value="$(arg enable_gnss_nis_state_machine)"/>
        <param name="gnss_health_window_size" type="int" value="$(arg gnss_health_window_size)"/>
        <param name="gnss_degraded_count_threshold" type="int" value="$(arg gnss_degraded_count_threshold)"/>
        <param name="gnss_severe_count_threshold" type="int" value="$(arg gnss_severe_count_threshold)"/>
        <param name="gnss_recover_count_threshold" type="int" value="$(arg gnss_recover_count_threshold)"/>
        <param name="gnss_isolation_time" type="double" value="$(arg gnss_isolation_time)"/>
        <param name="gnss_nis_degraded_threshold" type="double" value="$(arg gnss_nis_degraded_threshold)"/>
        <param name="gnss_nis_severe_threshold" type="double" value="$(arg gnss_nis_severe_threshold)"/>
        <param name="gnss_r_degraded_scale" type="double" value="$(arg gnss_r_degraded_scale)"/>
        <param name="gnss_r_severe_scale" type="double" value="$(arg gnss_r_severe_scale)"/>
        <param name="enable_odom_gnss_consistency_health" type="bool" value="$(arg enable_odom_gnss_consistency_health)"/>
        <param name="odom_gnss_consistency_threshold" type="double" value="$(arg odom_gnss_consistency_threshold)"/>
        <param name="odom_gnss_consistency_poor_threshold" type="double" value="$(arg odom_gnss_consistency_poor_threshold)"/>
        <param name="odom_gnss_consistency_max_scale" type="double" value="$(arg odom_gnss_consistency_max_scale)"/>
        <param name="odom_gnss_consistency_timeout" type="double" value="$(arg odom_gnss_consistency_timeout)"/>
        <param name="enable_gnss_yaw_alignment" type="bool" value="$(arg enable_gnss_yaw_alignment)"/>
        <param name="gnss_require_yaw_alignment_before_update" type="bool" value="$(arg gnss_require_yaw_alignment_before_update)"/>
        <param name="gnss_alignment_min_samples" type="int" value="$(arg gnss_alignment_min_samples)"/>
        <param name="gnss_alignment_max_samples" type="int" value="$(arg gnss_alignment_max_samples)"/>
        <param name="gnss_alignment_min_motion" type="double" value="$(arg gnss_alignment_min_motion)"/>
        <param name="gnss_alignment_sample_interval" type="double" value="$(arg gnss_alignment_sample_interval)"/>
        <param name="gnss_odom_sync_max_dt" type="double" value="$(arg gnss_odom_sync_max_dt)"/>
        <param name="gnss_alignment_max_residual" type="double" value="$(arg gnss_alignment_max_residual)"/>
        <param name="enable_gnss_alignment_refinement" type="bool" value="$(arg enable_gnss_alignment_refinement)"/>
        <param name="gnss_alignment_refinement_min_samples" type="int" value="$(arg gnss_alignment_refinement_min_samples)"/>
        <param name="gnss_alignment_refinement_max_samples" type="int" value="$(arg gnss_alignment_refinement_max_samples)"/>
        <param name="gnss_alignment_refinement_min_motion" type="double" value="$(arg gnss_alignment_refinement_min_motion)"/>
        <param name="gnss_alignment_refinement_max_residual" type="double" value="$(arg gnss_alignment_refinement_max_residual)"/>
        <param name="gnss_alignment_refinement_gain" type="double" value="$(arg gnss_alignment_refinement_gain)"/>
        <param name="gnss_alignment_refinement_max_yaw_step" type="double" value="$(arg gnss_alignment_refinement_max_yaw_step)"/>
        <param name="gnss_alignment_refinement_max_translation_step" type="double" value="$(arg gnss_alignment_refinement_max_translation_step)"/>
        <param name="gnss_min_status" type="int" value="0"/>
        <param name="path_publish_stride" type="int" value="$(arg path_publish_stride)"/>
        <param name="path_max_points" type="int" value="50000"/>
        <param name="arrow_publish_stride" type="int" value="30"/>
        <param name="arrow_max_markers" type="int" value="1000"/>
    </node>

    <node if="$(arg start_display_frames)" pkg="ekf" type="publish_display_frames.py" name="ekf_display_frames" output="screen">
        <param name="world_frame" type="str" value="odom"/>
        <param name="odom_frame" type="str" value="odom_input_frame"/>
        <param name="ekf_frame" type="str" value="ekf_base_link"/>
        <param name="gnss_frame" type="str" value="aligned_gnss_frame"/>
        <param name="odom_topic" type="str" value="$(arg odom_primary_topic)"/>
        <param name="ekf_topic" type="str" value="/ekf/ekf_odom"/>
        <param name="gnss_path_topic" type="str" value="/ekf/gnss_path"/>
        <param name="axis_marker_topic" type="str" value="/ekf/display_frame_axes"/>
        <param name="odom_axis_length" type="double" value="3.0"/>
        <param name="ekf_axis_length" type="double" value="4.5"/>
        <param name="gnss_axis_length" type="double" value="2.0"/>
        <param name="axis_shaft_diameter" type="double" value="0.08"/>
        <param name="axis_head_diameter" type="double" value="0.24"/>
        <param name="axis_head_length" type="double" value="0.36"/>
    </node>

    <node if="$(arg start_review_paths)" pkg="ekf" type="persist_review_paths.py" name="ekf_review_paths" output="screen">
        <param name="input_path_topic" type="str" value="/ekf/input_path"/>
        <param name="ekf_path_topic" type="str" value="/ekf/ekf_path"/>
        <param name="gnss_path_topic" type="str" value="/ekf/gnss_path"/>
        <param name="review_input_path_topic" type="str" value="/ekf/review/input_path"/>
        <param name="review_ekf_path_topic" type="str" value="/ekf/review/ekf_path"/>
        <param name="review_gnss_path_topic" type="str" value="/ekf/review/gnss_path"/>
        <param name="publish_hz" type="double" value="2.0"/>
        <param name="restamp_to_now" type="bool" value="true"/>
    </node>

    <node if="$(arg start_rviz)" pkg="rviz" type="rviz" name="ekf_rviz" args="-d $(arg rviz_config)" output="screen"/>

</launch>
